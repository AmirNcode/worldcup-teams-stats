# ─────────────────────────────────────────────────────────────────────────
# Monetization config. Everything here is OPTIONAL — with nothing set, the
# app shows no ads in production (and a labelled placeholder in `npm run dev`).
#
# To go live, set these in Netlify instead of committing them:
#   Site settings → Environment variables → Add a variable → redeploy.
# (They're not secret; AdSense IDs appear in page source regardless.)
# ─────────────────────────────────────────────────────────────────────────

# Google AdSense — from your approved AdSense account.
# CLIENT is your publisher id ("Account → Settings"); SLOT is the ad-unit id
# created under "Ads → By ad unit → Display ads".
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT=XXXXXXXXXX

# Direct-sold sponsor banner (used ONLY when the AdSense vars above are unset).
# Handy before AdSense approval, or to sell the slot to a single sponsor.
#VITE_SPONSOR_IMAGE=https://example.com/sponsor-banner.png
#VITE_SPONSOR_URL=https://example.com
#VITE_SPONSOR_ALT=Our sponsor
